# AFOS Analytics - Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores

# Firecrawl API Key (opcional - habilita scraping profundo de notícias)
# Obtenha em: https://firecrawl.dev
FIRECRAWL_API_KEY=

# Vercel KV (configurado automaticamente ao conectar KV no dashboard)
# Dashboard → Storage → Create KV Database → Connect to Project
# As variáveis abaixo são injetadas automaticamente pela Vercel:
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=

# Segredo para autenticar cron jobs (opcional, recomendado em produção)
# Gere com: openssl rand -hex 32
CRON_SECRET=

# Nota: Token de deploy Vercel NUNCA deve ser armazenado aqui
# Use Vercel CLI login ou CI/CD secrets
