# AFOS Analytics - Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores

# ─── Neon Postgres (banco principal) ────────────────────────────────
# Vercel Dashboard → Storage → Neon → Connect (env vars injetadas)
# Ou: console.neon.tech → Connection Details
# Pooled (runtime serverless) — usa pgbouncer
DATABASE_URL=
# Unpooled (migrations/admin) — conexão direta
DATABASE_URL_UNPOOLED=

# ─── Upstash Redis (obrigatório para Cron + KV) ─────────────────────
# Opção A: Vercel Dashboard → Marketplace → "Upstash" → Install → Connect
#          (env vars injetadas automaticamente)
# Opção B: console.upstash.com → Create Database → copiar valores
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Firecrawl (opcional - scraping de notícias) ────────────────────
# Obtenha em: https://firecrawl.dev
FIRECRAWL_API_KEY=

# ─── Cron (opcional - autenticação de cron jobs) ────────────────────
# Gere com: openssl rand -hex 32
CRON_SECRET=

# ─── Resend (emails - alertas, newsletter, welcome) ────────────────
# Obtenha em: https://resend.com (plano gratuito: 100 emails/dia)
RESEND_API_KEY=
# Email que recebe alertas do sistema (ex: falha do cron de persistência)
ALERT_EMAIL=

# ─── Vercel Blob (opcional - backup redundante de análises) ────────
# Vercel Dashboard → Storage → Create Blob Store → copy token
# Se vazio, backup em Blob é pulado (Neon continua sendo fonte primária)
BLOB_READ_WRITE_TOKEN=

# ─── Tradução por IA (opcional - pipeline de tradução) ─────────────
# Provider: "anthropic" ou "openai"
TRANSLATION_PROVIDER=anthropic
# API key do provider escolhido
TRANSLATION_API_KEY=
# Token de autenticação para POST /api/translations
# Gere com: openssl rand -hex 32
TRANSLATION_AUTH_TOKEN=

# ─── Google Search Console (opcional - SEO analytics) ──────────────
# Criar service account: https://console.cloud.google.com/iam-admin/serviceaccounts
# Habilitar Search Console API, adicionar service account como usuário no GSC
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SEARCH_CONSOLE_SITE_URL=

# ─── Vercel (auto-injetado em produção) ────────────────────────────
# Aliases do Upstash Redis injetados pelo Vercel Marketplace
# KV_REST_API_URL=    (alias de UPSTASH_REDIS_REST_URL)
# KV_REST_API_TOKEN=  (alias de UPSTASH_REDIS_REST_TOKEN)

# Nota: Token de deploy Vercel NUNCA deve ser armazenado aqui
