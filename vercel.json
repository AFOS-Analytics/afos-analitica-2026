{
  "ignoreCommand": "git diff --name-only HEAD^ HEAD|grep -qvE '^(docs|tests|scripts)/|^(README|CONTRIBUTING|SECURITY|TRADEMARK|CODE_OF_CONDUCT)\\.md$|^(LICENSE|NOTICE)$'&&exit 1||exit 0",
  "crons": [
    {
      "path": "/api/cron/refresh-elections",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/refresh-polls",
      "schedule": "0 6,12,18 * * *"
    },
    {
      "path": "/api/cron/persist-analysis",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/purge-visitor-state",
      "schedule": "0 4 * * *"
    }
  ]
}
