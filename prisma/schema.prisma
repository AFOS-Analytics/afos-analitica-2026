// AFOS Analytics — Prisma Schema
// 6 schemas: iam, crm, research, market, governance, ai
// Neon Postgres — pooled (runtime) + unpooled (migrations)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["iam", "crm", "research", "market", "governance", "ai"]
}

// ═══════════════════════════════════════════════════════════
// GOVERNANCE — Audit trail, system events, data versioning
// ═══════════════════════════════════════════════════════════

model AuditLog {
  id        String   @id @default(cuid())
  actor     String?
  action    String
  resource  String
  detail    Json?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([action, createdAt])
  @@index([resource, createdAt])
  @@index([createdAt]) // purge cron
  @@map("audit_log")
  @@schema("governance")
}

model SystemEvent {
  id        String   @id @default(cuid())
  eventType String   @map("event_type")
  severity  String   // info, warn, error, critical
  message   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventType, createdAt])
  @@index([severity, createdAt])
  @@map("system_events")
  @@schema("governance")
}

model DataVersion {
  id        String   @id @default(cuid())
  tableName String   @map("table_name")
  recordId  String   @map("record_id")
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  changedBy String?  @map("changed_by")
  changedAt DateTime @default(now()) @map("changed_at")

  @@index([tableName, recordId])
  @@map("data_versions")
  @@schema("governance")
}

// ═══════════════════════════════════════════════════════════
// CRM — Leads, events, campaigns
// ═══════════════════════════════════════════════════════════

model Lead {
  id             String      @id @default(cuid())
  email          String      @unique
  source         String
  status         String      @default("active")
  consentVersion String      @default("1.0") @map("consent_version")
  consentHash    String?     @map("consent_hash")
  ip             String?
  userAgent      String?     @map("user_agent")
  locale         String?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  events         LeadEvent[]

  @@index([status, createdAt])
  @@map("leads")
  @@schema("crm")
}

model LeadEvent {
  id        String   @id @default(cuid())
  leadId    String   @map("lead_id")
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  eventType String   @map("event_type")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([leadId, createdAt])
  @@map("lead_events")
  @@schema("crm")
}

// ═══════════════════════════════════════════════════════════
// IAM — Users, preferences, consents
// ═══════════════════════════════════════════════════════════

model User {
  id          String           @id @default(cuid())
  email       String           @unique
  name        String?
  locale      String           @default("pt-BR")
  role        String           @default("viewer")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  preferences UserPreference[]
  consents    Consent[]

  @@map("users")
  @@schema("iam")
}

model UserPreference {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  key    String
  value  String

  @@unique([userId, key])
  @@map("user_preferences")
  @@schema("iam")
}

model Consent {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  version     String
  granted     Boolean
  consentHash String?  @map("consent_hash")
  ip          String?
  userAgent   String?  @map("user_agent")
  grantedAt   DateTime @default(now()) @map("granted_at")

  @@index([userId, type])
  @@map("consents")
  @@schema("iam")
}

// ═══════════════════════════════════════════════════════════
// RESEARCH — Institutes, polls, scenarios, analyses
// ═══════════════════════════════════════════════════════════

model Institute {
  id          String @id @default(cuid())
  name        String @unique
  reliability Int
  type        String
  note        String?
  polls       Poll[]

  @@map("institutes")
  @@schema("research")
}

model Poll {
  id           String         @id @default(cuid())
  instituteId  String         @map("institute_id")
  institute    Institute      @relation(fields: [instituteId], references: [id])
  date         String
  sample       Int
  margin       Float
  register     String
  method       String?
  scenarios    PollScenario[]
  secondRounds SecondRound[]
  createdAt    DateTime       @default(now()) @map("created_at")

  @@index([instituteId, date])
  @@map("polls")
  @@schema("research")
}

model PollScenario {
  id      String       @id @default(cuid())
  pollId  String       @map("poll_id")
  poll    Poll         @relation(fields: [pollId], references: [id], onDelete: Cascade)
  name    String
  results PollResult[]

  @@map("poll_scenarios")
  @@schema("research")
}

model PollResult {
  id         String       @id @default(cuid())
  scenarioId String       @map("scenario_id")
  scenario   PollScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  candidate  String
  percent    Float

  @@map("poll_results")
  @@schema("research")
}

model SecondRound {
  id         String @id @default(cuid())
  pollId     String @map("poll_id")
  poll       Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  matchup    String
  candidate1 String
  percent1   Float
  candidate2 String
  percent2   Float

  @@map("second_rounds")
  @@schema("research")
}

model Analysis {
  id          String   @id @default(cuid())
  type        String
  content     Json
  publishedAt DateTime @map("published_at")
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([type, publishedAt])
  @@map("analyses")
  @@schema("research")
}

// ═══════════════════════════════════════════════════════════
// MARKET — Snapshots, odds, signals, cross-analytics
// ═══════════════════════════════════════════════════════════

model MarketSnapshot {
  id        String          @id @default(cuid())
  slug      String
  country   String?
  fetchedAt DateTime        @map("fetched_at")
  rawData   Json            @map("raw_data")
  odds      CandidateOdd[]

  @@index([slug, fetchedAt])
  @@index([country, fetchedAt])
  @@index([fetchedAt]) // purge cron: DELETE WHERE fetched_at < 90 days
  @@map("market_snapshots")
  @@schema("market")
}

model CandidateOdd {
  id          String         @id @default(cuid())
  snapshotId  String         @map("snapshot_id")
  snapshot    MarketSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  candidate   String
  probability Float
  volume      Float

  @@index([candidate, probability])
  @@map("candidates_odds")
  @@schema("market")
}

model MarketSignal {
  id         String   @id @default(cuid())
  signalType String   @map("signal_type")
  country    String
  data       Json
  detectedAt DateTime @map("detected_at")

  @@index([signalType, detectedAt])
  @@index([country, detectedAt])
  @@map("market_signals")
  @@schema("market")
}

model CrossAnalytic {
  id          String   @id @default(cuid())
  type        String
  leftSource  String   @map("left_source")
  rightSource String   @map("right_source")
  result      Json
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([type, createdAt])
  @@map("cross_analytics")
  @@schema("market")
}

// ═══════════════════════════════════════════════════════════
// AI — Translations, validations, LLM call tracking
// ═══════════════════════════════════════════════════════════

model Translation {
  id             String                  @id @default(cuid())
  sourceLocale   String                  @map("source_locale")
  targetLocale   String                  @map("target_locale")
  sourceHash     String                  @map("source_hash")
  sourceText     String                  @map("source_text")
  translatedText String                  @map("translated_text")
  provider       String?
  cached         Boolean                 @default(false)
  validations    TranslationValidation[]
  createdAt      DateTime                @default(now()) @map("created_at")

  @@unique([sourceHash, targetLocale])
  @@index([sourceLocale, targetLocale])
  @@map("translations")
  @@schema("ai")
}

model TranslationValidation {
  id            String      @id @default(cuid())
  translationId String      @map("translation_id")
  translation   Translation @relation(fields: [translationId], references: [id], onDelete: Cascade)
  checkName     String      @map("check_name")
  passed        Boolean
  detail        String?

  @@map("translation_validations")
  @@schema("ai")
}

model LlmCall {
  id        String   @id @default(cuid())
  provider  String
  model     String
  purpose   String
  tokensIn  Int      @map("tokens_in")
  tokensOut Int      @map("tokens_out")
  latencyMs Int      @map("latency_ms")
  costUsd   Float?   @map("cost_usd")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([provider, createdAt])
  @@index([purpose, createdAt])
  @@index([createdAt]) // purge cron + cost tracking
  @@map("llm_calls")
  @@schema("ai")
}
