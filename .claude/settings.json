{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/check-factcheck-emitted.py",
            "shell": "bash",
            "timeout": 10,
            "statusMessage": "Verificando fact-check gate (afos-daily)..."
          }
        ]
      }
    ]
  }
}
